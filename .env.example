APP_NAME=TicketingSaaS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

# --- CONFIGURAZIONE DOMINI ---
# Il dominio principale (senza sottodomini)
APP_CENTRAL_DOMAIN=localhost

# --- CONFIGURAZIONE DATABASE ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ticketing
DB_USERNAME=root
DB_PASSWORD=

# --- CONFIGURAZIONE MULTI-TENANCY ---
# Nome del database fisico per i tenant del piano "Base" (Shared)
SHARED_DB_NAME=ticketing_shared

# --- DRIVER DI SISTEMA ---
LOG_CHANNEL=stack
LOG_STACK=single

BCRYPT_ROUNDS=12

CACHE_STORE=database
CACHE_PREFIX=

FILESYSTEM_DISK=local

QUEUE_CONNECTION=database

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# --- CONFIGURAZIONE MAIL (Placeholder) ---
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- FIREBASE JWT (Per il Giorno 3) ---
# JWT_SECRET_KEY=
# JWT_ALGORITHM=HS256

# --- VITE ---
VITE_APP_NAME="${APP_NAME}"

#JWT
JWT_SECRET=la_tua_super_chiave_segreta_di_test_per_jwt_2026

REDIS_PREFIX=
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

QUEUE_CONNECTION=database