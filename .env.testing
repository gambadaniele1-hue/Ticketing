APP_ENV=testing
APP_KEY=base64:IL_TUO_APP_KEY_GENERATO_DA_LARAVEL

# IMPORTANTE: La chiave per i JWT
# Deve essere lunga almeno 32 caratteri per HS256
JWT_SECRET=UnAltraChiaveSegretaMoltoLungaEComplessaDiAlmeno32Char

# Configurazione Database di Test
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ticketing_testing
DB_USERNAME=root
DB_PASSWORD=

# Configurazione Tenancy (Indispensabile per i test dei domini)
CENTRAL_DOMAINS=localhost